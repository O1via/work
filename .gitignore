# Track only the py directory and this ignore file.
/*
!/py/
!/py/**
!.gitignore

# Ignore Python bytecode/cache artifacts under py.
py/**/__pycache__/
py/**/*.pyc

git add -A && git commit -m "chore: track only py directory"


# Allow off_node submodule managed under work repo
!.gitmodules
!/external/
!/external/off_node/
